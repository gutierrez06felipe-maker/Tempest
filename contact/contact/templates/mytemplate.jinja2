
{% extends "layout.jinja2" %}

{% block title %}TEMPEST SPORT{% endblock title %}

{% block head_extra %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;700;900&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--bg:#000;--panel:#101014;--soft:#18181b;--line:#2a2a31;--muted:#8d8d98;--text:#fff;--mono:'JetBrains Mono',monospace;--sans:'Montserrat',sans-serif}
html{scroll-behavior:smooth}body{font-family:var(--sans);background:#000;color:var(--text);overflow-x:hidden}a{text-decoration:none;color:inherit}button,input,select{font:inherit}button{border:0;background:none;cursor:pointer}
.hidden{display:none!important}.page{display:none}.page.active{display:block}.container{width:min(1240px,calc(100% - 2rem));margin:0 auto}
#bg{position:fixed;inset:0;z-index:-1;background:radial-gradient(circle at 20% 20%,rgba(255,255,255,.06),transparent 35%),radial-gradient(circle at 75% 30%,rgba(255,255,255,.04),transparent 25%),#000}#bg-canvas{position:absolute;inset:0;opacity:.28}.bg-word{position:absolute;inset:0;display:grid;place-items:center;font-size:min(28vw,18rem);font-style:italic;font-weight:900;letter-spacing:-.08em;color:rgba(255,255,255,.03);user-select:none}
#navbar{position:sticky;top:0;z-index:40;background:rgba(0,0,0,.82);backdrop-filter:blur(14px);border-bottom:1px solid var(--line)}.nav{height:68px;display:flex;align-items:center;justify-content:space-between;gap:1rem}.brand{display:flex;align-items:center;gap:.65rem;font-size:1.2rem;font-style:italic;font-weight:900;letter-spacing:.18em;text-transform:uppercase}.brand svg{width:30px;height:30px;fill:#fff}.nav-links,.nav-actions{display:flex;align-items:center;gap:1.25rem}.nav-link,.nav-btn{font-size:.68rem;text-transform:uppercase;font-weight:900;letter-spacing:.2em;color:var(--muted)}.nav-link.active,.nav-link:hover,.nav-btn:hover{color:#fff}.cart-btn{position:relative}.badge{position:absolute;top:-8px;right:-8px;background:#fff;color:#000;font-size:.55rem;font-weight:900;padding:2px 6px}
.hero{min-height:88vh;display:grid;place-items:center;text-align:center;padding:3rem 0}.hero h1{font-size:clamp(3rem,11vw,7rem);line-height:.95;font-style:italic;font-weight:900;letter-spacing:-.06em}.hero h1 span,.section-title span{color:#5e5e66}.hero p{max-width:720px;margin:1.5rem auto 2rem;color:#b2b2bb;text-transform:uppercase;letter-spacing:.12em;font-size:.95rem}.cta-row{display:flex;justify-content:center;gap:1rem;flex-wrap:wrap}
.btn-primary,.btn-outline,.btn-sm{display:inline-flex;align-items:center;justify-content:center;gap:.5rem;text-transform:uppercase;font-weight:900;letter-spacing:.2em}.btn-primary{padding:1rem 1.75rem;background:#fff;color:#000;font-size:.72rem}.btn-outline{padding:1rem 1.75rem;border:2px solid #fff;color:#fff;font-size:.72rem}.btn-sm{padding:.6rem 1rem;background:#fff;color:#000;font-size:.62rem}
section.block{padding:5rem 0;border-top:1px solid var(--line)}.section-label{display:block;margin-bottom:.5rem;padding-left:.75rem;border-left:3px solid #fff;font-size:.62rem;text-transform:uppercase;font-weight:900;letter-spacing:.25em}.section-title{font-size:clamp(2rem,6vw,4rem);font-style:italic;font-weight:900;letter-spacing:-.05em;line-height:1}.section-head{display:flex;justify-content:space-between;align-items:end;gap:1rem;flex-wrap:wrap;margin-bottom:2rem}.see-link{font-size:.72rem;color:var(--muted);text-transform:uppercase;font-weight:700;letter-spacing:.14em}
.grid{display:grid;gap:1.5rem}.products{grid-template-columns:repeat(auto-fit,minmax(250px,1fr))}.card{background:rgba(16,16,20,.72);border:1px solid var(--line);overflow:hidden;transition:transform .25s ease,border-color .25s ease;cursor:pointer}.card:hover{transform:translateY(-6px);border-color:#53535f}.card figure{position:relative;aspect-ratio:3/4;overflow:hidden}.card img{width:100%;height:100%;object-fit:cover;filter:grayscale(1);transition:transform .6s ease,filter .3s ease}.card:hover img{transform:scale(1.06);filter:grayscale(0)}.chip{position:absolute;top:.8rem;left:.8rem;background:rgba(0,0,0,.75);border:1px solid var(--line);padding:.3rem .55rem;font-size:.5rem;font-weight:900;letter-spacing:.18em;text-transform:uppercase}.gender{position:absolute;right:.8rem;bottom:.8rem;background:#fff;color:#000;padding:.2rem .55rem;font-size:.5rem;font-weight:900;letter-spacing:.15em;text-transform:uppercase}.card-body{padding:1.2rem}.card-top,.row{display:flex;justify-content:space-between;gap:.75rem}.cat,.mini{font-size:.55rem;color:#777784;text-transform:uppercase;font-weight:900;letter-spacing:.2em}.name{margin:.45rem 0;font-size:.7rem;text-transform:uppercase;font-weight:900;letter-spacing:.15em}.desc{font-size:.68rem;color:#9b9ba5;line-height:1.45;min-height:2.9em}.price{margin-top:1rem;padding-top:1rem;border-top:1px solid #1f1f27;font-family:var(--mono);font-size:1.05rem}
.features,.services{grid-template-columns:repeat(auto-fit,minmax(220px,1fr))}.feature,.service,.panel,.auth-card,.summary,.detail-box,.about-box{background:rgba(16,16,20,.72);border:1px solid var(--line)}.feature,.service{padding:1.7rem}.feature h3,.service h3{margin:1rem 0 .6rem;font-size:.78rem;text-transform:uppercase;letter-spacing:.16em}.feature p,.service p,.about-box p{color:#a2a2ad;line-height:1.6;font-size:.82rem}
.catalog-tools{display:grid;gap:1rem;margin:2rem 0}.search{width:100%;background:transparent;border:0;border-bottom:1px solid var(--line);padding:1rem 0;color:#fff}.filters{display:flex;gap:.5rem;flex-wrap:wrap}.filter{padding:.55rem 1rem;border:1px solid var(--line);font-size:.58rem;text-transform:uppercase;font-weight:900;letter-spacing:.18em;color:var(--muted)}.filter.active{background:#fff;color:#000;border-color:#fff}.count{font-family:var(--mono);font-size:.72rem;color:var(--muted)}
.detail-grid,.cart-grid,.checkout-grid,.admin-grid,.about-grid{display:grid;gap:2rem}.detail-grid{grid-template-columns:1fr 1fr}.detail-main{aspect-ratio:3/4;border:1px solid var(--line);overflow:hidden}.detail-main img{width:100%;height:100%;object-fit:cover}.thumbs{display:flex;gap:.5rem;margin-top:.5rem}.thumbs img{width:64px;height:80px;object-fit:cover;border:1px solid var(--line);opacity:.55;cursor:pointer}.thumbs img.active{opacity:1;border-color:#fff}.detail-box{padding:1.5rem}.detail-box h1{font-size:clamp(1.8rem,4vw,3rem);font-style:italic;letter-spacing:-.04em;text-transform:uppercase}.detail-box p{margin:1rem 0 1.5rem;color:#a3a3ac;line-height:1.7}
.option-label{display:block;margin:1rem 0 .7rem;font-size:.62rem;color:var(--muted);font-weight:900;text-transform:uppercase;letter-spacing:.2em}.sizes,.colors{display:flex;gap:.5rem;flex-wrap:wrap}.size-btn,.color-btn{padding:.55rem .9rem;border:1px solid var(--line);color:#b2b2bc;text-transform:uppercase;font-size:.62rem;font-weight:900;letter-spacing:.15em}.size-btn.selected,.color-btn.selected{background:#fff;color:#000;border-color:#fff}.swatch{display:inline-block;width:12px;height:12px;border-radius:999px;margin-right:.35rem;border:1px solid #666;vertical-align:-1px}
.cart-grid,.checkout-grid{grid-template-columns:minmax(0,1fr) 340px}.cart-item{display:flex;gap:1rem;padding:1rem;border:1px solid var(--line);background:rgba(16,16,20,.72);margin-bottom:1rem}.cart-item img{width:96px;height:128px;object-fit:cover}.cart-info h3{font-size:.95rem;text-transform:uppercase}.cart-info p{margin:.35rem 0;color:#9d9da7;font-size:.72rem}.summary{padding:1.5rem;position:sticky;top:5rem}.summary h3,.panel h3{padding-bottom:1rem;margin-bottom:1rem;border-bottom:1px solid var(--line);font-size:.95rem;font-style:italic;text-transform:uppercase}.sum-row{display:flex;justify-content:space-between;gap:1rem;margin:.8rem 0;color:#b0b0b8;font-size:.7rem;text-transform:uppercase;letter-spacing:.15em}.sum-row.total{padding-top:1rem;border-top:1px solid var(--line);color:#fff}
.auth-wrap{min-height:100vh;display:grid;place-items:center;padding:4rem 0}.auth-card{width:min(460px,100%);padding:2rem}.auth-card h1{text-align:center;font-size:2rem;font-style:italic;text-transform:uppercase}.auth-card p.sub{text-align:center;color:var(--muted);font-size:.65rem;letter-spacing:.2em;text-transform:uppercase;margin:.5rem 0 2rem}.field{margin-bottom:1rem}.field label{display:block;margin-bottom:.45rem;font-size:.62rem;text-transform:uppercase;font-weight:900;letter-spacing:.18em}.field input,.field select{width:100%;padding:.85rem 1rem;background:#050506;border:1px solid var(--line);color:#fff}
.panel{padding:1.5rem}.admin-grid{grid-template-columns:240px minmax(0,1fr)}.admin-menu{display:grid;gap:.35rem}.admin-tab{padding:.85rem 1rem;text-align:left;border-left:3px solid transparent;color:var(--muted);text-transform:uppercase;font-size:.66rem;font-weight:900;letter-spacing:.16em}.admin-tab.active{background:rgba(255,255,255,.04);border-left-color:#fff;color:#fff}.stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:1rem;margin-bottom:1.5rem}.stat{padding:1.2rem;border:1px solid var(--line);background:rgba(16,16,20,.72)}.stat strong{display:block;font-family:var(--mono);font-size:1.4rem}.stat span{font-size:.62rem;color:var(--muted);text-transform:uppercase;letter-spacing:.18em}
table{width:100%;border-collapse:collapse}th,td{padding:.8rem;text-align:left;border-bottom:1px solid var(--line)}th{font-size:.56rem;color:var(--muted);text-transform:uppercase;letter-spacing:.2em}td{font-size:.76rem}.status{padding:.25rem .6rem;border:1px solid currentColor;font-size:.55rem;font-weight:900;text-transform:uppercase;letter-spacing:.14em}.status.pendiente{color:#facc15}.status.procesando{color:#60a5fa}.status.entregado{color:#22c55e}
.about-grid{grid-template-columns:1fr 1fr}.about-box{padding:2rem}.about-box h2{margin-bottom:1rem;font-size:1.7rem;font-style:italic;text-transform:uppercase}.footer{padding:3rem 0;border-top:1px solid var(--line);text-align:center;color:#6e6e78}.footer strong{display:block;margin-bottom:.5rem;color:#fff;font-style:italic;letter-spacing:.2em}
@media(max-width:960px){.detail-grid,.cart-grid,.checkout-grid,.admin-grid,.about-grid{grid-template-columns:1fr}}@media(max-width:760px){.nav-links{display:none}.section-head{align-items:flex-start}.hero p{font-size:.85rem}}
</style>
{% endblock head_extra %}

{% block content %}
<div id="bg"><canvas id="bg-canvas"></canvas><div class="bg-word">TEMPEST</div></div>
<nav id="navbar"><div class="container nav"><a href="#" class="brand" data-page="home"><svg viewBox="0 0 32 32"><polygon points="18,2 8,18 16,18 14,30 24,14 16,14"></polygon></svg>TEMPEST</a><div class="nav-links"><a href="#" class="nav-link active" data-page="home">Inicio</a><a href="#" class="nav-link" data-page="catalog">Catalogo</a><a href="#" class="nav-link" data-page="about">Nosotros</a></div><div class="nav-actions"><div id="auth-area"></div><button class="nav-btn cart-btn" id="cart-nav">Carrito <span id="cart-badge" class="badge hidden">0</span></button></div></div></nav>
<div id="home-page" class="page active"><section class="hero container"><div><h1>DOMINA LA<br><span>TORMENTA</span></h1><p>Ropa deportiva de alto rendimiento pensada para atletas que entrenan con disciplina, caracter y presencia.</p><div class="cta-row"><a href="#" class="btn-primary" data-page="catalog">Comprar Ahora</a><a href="#" class="btn-outline" data-page="register" id="hero-register">Crear Cuenta</a></div></div></section><section class="block"><div class="container"><div class="section-head"><div><span class="section-label">Destacados</span><h2 class="section-title">Nuevos <span>Ingresos</span></h2></div><a href="#" class="see-link" data-page="catalog">Ver catalogo completo</a></div><div id="featured-grid" class="grid products"></div></div></section><section class="block"><div class="container grid features"><article class="feature"><h3>Maximo Rendimiento</h3><p>Prendas tecnicas con ajuste atletico, secado rapido y materiales listos para entrenar fuerte.</p></article><article class="feature"><h3>Durabilidad Extrema</h3><p>Costuras reforzadas y telas resistentes para soportar rutinas intensas y uso continuo.</p></article><article class="feature"><h3>Garantia Tempest</h3><p>Cambios simples si la talla no encaja como debe.</p></article></div></section><section class="block"><div class="container"><div class="section-head"><div><span class="section-label">Servicios</span><h2 class="section-title">Experiencia <span>Completa</span></h2></div></div><div class="grid services"><article class="service"><h3>Seguimiento de Pedidos</h3><p>Consulta tu historial y el estado de cada compra en un solo lugar.</p></article><article class="service"><h3>Soporte 24/7</h3><p>Acompanamiento para compras, cambios y cualquier duda sobre el catalogo.</p></article><article class="service"><h3>Pagos Seguros</h3><p>Tarjeta, PSE, Nequi y contra entrega para adaptarnos a tu forma de compra.</p></article></div></div></section><div class="footer"><strong>TEMPEST</strong>Domina la tormenta · Alto rendimiento</div></div>
<div id="catalog-page" class="page"><section class="block"><div class="container"><div class="section-head"><div><span class="section-label">Equipamiento Elite</span><h1 class="section-title">Catalogo <span>Tempest</span></h1></div><div id="product-count" class="count">[0] PRODUCTOS</div></div><div class="catalog-tools"><input id="search-input" class="search" type="text" placeholder="Buscar por nombre o categoria..."><div class="filters" id="gender-filters"><button class="filter active" data-gender="All">Todos</button><button class="filter" data-gender="Men">Hombre</button><button class="filter" data-gender="Women">Mujer</button><button class="filter" data-gender="Unisex">Unisex</button></div><div class="filters" id="category-filters"></div></div><div id="catalog-grid" class="grid products"></div></div></section></div>
<div id="product-detail-page" class="page"><section class="block"><div class="container"><a href="#" class="see-link" id="back-catalog">Volver al catalogo</a><div class="detail-grid" style="margin-top:1.5rem"><div><div class="detail-main"><img id="detail-image" src="" alt=""></div><div class="thumbs" id="detail-thumbs"></div></div><div class="detail-box"><div id="detail-cat" class="mini"></div><h1 id="detail-name"></h1><div id="detail-price" class="price"></div><p id="detail-desc"></p><span class="option-label">Color</span><div id="color-options" class="colors"></div><span class="option-label">Talla</span><div id="size-options" class="sizes"></div><button id="add-cart" class="btn-primary" style="margin-top:1rem;width:100%">Agregar al carrito</button></div></div></div></section></div>
<div id="cart-page" class="page"><section class="block"><div class="container"><h1 class="section-title" style="margin-bottom:2rem">Tu <span>Carrito</span></h1><div class="cart-grid"><div id="cart-list"></div><aside class="summary"><h3>Resumen</h3><div class="sum-row"><span>Productos</span><span id="sum-count">0</span></div><div class="sum-row"><span>Subtotal</span><span id="sum-sub">$0</span></div><div class="sum-row"><span>Envio</span><span>Gratis</span></div><div class="sum-row total"><span>Total</span><span id="sum-total">$0</span></div><button id="go-checkout" class="btn-primary" style="width:100%;margin-top:1rem">Finalizar compra</button></aside></div></div></section></div>
<div id="checkout-page" class="page"><section class="block"><div class="container"><h1 class="section-title" style="margin-bottom:2rem">Finalizar <span>Compra</span></h1><div class="checkout-grid"><div class="panel"><h3>Informacion de Entrega</h3><div class="field"><label>Nombre</label><input id="co-name" type="text"></div><div class="field"><label>Telefono</label><input id="co-phone" type="text"></div><div class="field"><label>Direccion</label><input id="co-address" type="text"></div><div class="field"><label>Ciudad</label><input id="co-city" type="text"></div><div class="field"><label>Metodo de Pago</label><select id="co-payment"><option value="tarjeta">Tarjeta</option><option value="pse">PSE</option><option value="nequi">Nequi</option><option value="contra_entrega">Contra Entrega</option></select></div></div><aside class="summary"><h3>Tu Pedido</h3><div id="checkout-items"></div><div class="sum-row total"><span>Total</span><span id="checkout-total">$0</span></div><button id="place-order" class="btn-primary" style="width:100%;margin-top:1rem">Confirmar pedido</button></aside></div></div></section></div>
<div id="orders-page" class="page"><section class="block"><div class="container"><h1 class="section-title" style="margin-bottom:2rem">Mis <span>Pedidos</span></h1><div id="orders-list"></div></div></section></div>
<div id="login-page" class="page"><div class="auth-wrap container"><div class="auth-card"><h1>Iniciar Sesion</h1><p class="sub">Accede a tu cuenta Tempest</p><form id="login-form"><div class="field"><label>Correo</label><input id="login-email" type="email" required></div><div class="field"><label>Contrasena</label><input id="login-password" type="password" required></div><button class="btn-primary" style="width:100%" type="submit">Ingresar</button></form><p class="sub" style="margin-top:1.2rem">Demo cliente: cliente@tempest.com / tempest123</p></div></div></div>
<div id="register-page" class="page"><div class="auth-wrap container"><div class="auth-card"><h1>Crear Cuenta</h1><p class="sub">Unete a la familia Tempest</p><form id="register-form"><div class="field"><label>Nombre</label><input id="reg-name" type="text" required></div><div class="field"><label>Correo</label><input id="reg-email" type="email" required></div><div class="field"><label>Contrasena</label><input id="reg-password" type="password" minlength="6" required></div><button class="btn-primary" style="width:100%" type="submit">Crear Cuenta</button></form></div></div></div>
<div id="admin-page" class="page"><section class="block"><div class="container admin-grid"><aside class="panel admin-menu"><button class="admin-tab active" data-admin="stats">Dashboard</button><button class="admin-tab" data-admin="orders">Pedidos</button><button class="admin-tab" data-admin="users">Usuarios</button></aside><div><div id="admin-stats-panel" class="admin-panel-live"><div id="stats-grid" class="stats"></div></div><div id="admin-orders-panel" class="admin-panel-live hidden panel"><h3>Pedidos</h3><table><thead><tr><th>ID</th><th>Cliente</th><th>Total</th><th>Estado</th></tr></thead><tbody id="admin-orders"></tbody></table></div><div id="admin-users-panel" class="admin-panel-live hidden panel"><h3>Usuarios</h3><table><thead><tr><th>Nombre</th><th>Email</th><th>Rol</th></tr></thead><tbody id="admin-users"></tbody></table></div></div></div></section></div>
<div id="about-page" class="page"><section class="block"><div class="container"><div class="section-head"><div><span class="section-label">Marca</span><h1 class="section-title">Nuestra <span>Historia</span></h1></div></div><div class="about-grid"><article class="about-box"><h2>El Origen</h2><p>Tempest nace para unir funcionalidad, disciplina visual y actitud competitiva en un mismo lenguaje de marca.</p></article><article class="about-box"><h2>La Vision</h2><p>Construir una experiencia de compra directa, intensa y moderna para atletas de alto rendimiento en Latinoamerica.</p></article></div></div></section></div>
{% endblock content %}

{% block scripts %}
<script>
const PRODUCTS={{ products_json|safe }};
const S={page:'home',search:'',gender:'All',category:'All',product:null,size:null,color:null,cart:[],user:null};
const $=id=>document.getElementById(id);
const money=v=>'$'+v.toLocaleString('es-CO');
function initLightning(){const c=$('bg-canvas'),x=c.getContext('2d');let w,h,bolts=[];const resize=()=>{w=c.width=innerWidth;h=c.height=innerHeight};resize();addEventListener('resize',resize);(function draw(){x.clearRect(0,0,w,h);if(Math.random()<.006)bolts.push({x:Math.random()*w,life:18});x.strokeStyle='rgba(255,255,255,.16)';x.lineWidth=1;bolts=bolts.filter(b=>{if(b.life<=0)return false;let cx=b.x,cy=0;x.beginPath();x.moveTo(cx,cy);for(let i=0;i<9;i++){cx+=(Math.random()-.5)*36;cy+=h/9;x.lineTo(cx,cy)}x.globalAlpha=b.life/18;x.stroke();x.globalAlpha=1;b.life--;return true});requestAnimationFrame(draw)})()}
function saveUser(){localStorage.setItem('tempest_user',JSON.stringify(S.user))}
function loadData(){const users=JSON.parse(localStorage.getItem('tempest_users')||'null');if(!users){localStorage.setItem('tempest_users',JSON.stringify([{id:'demo_client',name:'Cliente Demo',email:'cliente@tempest.com',role:'cliente',createdAt:new Date().toISOString()},{id:'demo_admin',name:'Admin Tempest',email:'admin@tempest.com',role:'admin',createdAt:new Date().toISOString()}]));localStorage.setItem('tempest_passwords',JSON.stringify({'cliente@tempest.com':'tempest123','admin@tempest.com':'tempest123'}))}S.user=JSON.parse(localStorage.getItem('tempest_user')||'null')}
function card(p){return `<article class="card" data-id="${p.id}"><figure><span class="chip">TEMPEST</span><img src="${p.image}" alt="${p.name}"><span class="gender">${p.gender}</span></figure><div class="card-body"><div class="card-top"><span class="cat">[${p.category}]</span><span class="mini">Premium</span></div><div class="name">${p.name}</div><p class="desc">${p.description}</p><div class="price">${money(p.price)}</div></div></article>`}
function bindCards(root){root.querySelectorAll('.card').forEach(el=>el.onclick=()=>navigate('product-detail',PRODUCTS.find(p=>p.id===el.dataset.id)))}
function renderFeatured(){const el=$('featured-grid');el.innerHTML=PRODUCTS.slice(0,3).map(card).join('');bindCards(el)}
function renderCatalog(){const cats=[...new Set(PRODUCTS.map(p=>p.category))];$('category-filters').innerHTML=['<button class="filter'+(S.category==='All'?' active':'')+'" data-category="All">Todas</button>',...cats.map(c=>`<button class="filter${S.category===c?' active':''}" data-category="${c}">${c}</button>`)].join('');const list=PRODUCTS.filter(p=>{const q=S.search.toLowerCase();return(!q||p.name.toLowerCase().includes(q)||p.category.toLowerCase().includes(q))&&(S.gender==='All'||p.gender===S.gender)&&(S.category==='All'||p.category===S.category)});$('product-count').textContent=`[${list.length}] PRODUCTOS`;const grid=$('catalog-grid');grid.innerHTML=list.map(card).join('');bindCards(grid);document.querySelectorAll('#gender-filters .filter').forEach(b=>b.classList.toggle('active',b.dataset.gender===S.gender));document.querySelectorAll('#category-filters .filter').forEach(b=>b.onclick=()=>{S.category=b.dataset.category;renderCatalog()})}
function renderDetail(p){S.product=p;S.size=null;S.color=p.colors?.[0]?.name||null;$('detail-image').src=p.image;$('detail-name').textContent=p.name;$('detail-cat').textContent=`${p.category} / ${p.gender}`;$('detail-price').textContent=money(p.price);$('detail-desc').textContent=p.description;const thumbs=$('detail-thumbs');thumbs.innerHTML=(p.gallery||[p.image]).map((img,i)=>`<img src="${img}" class="${i===0?'active':''}">`).join('');thumbs.querySelectorAll('img').forEach(img=>img.onclick=()=>{$('detail-image').src=img.src;thumbs.querySelectorAll('img').forEach(x=>x.classList.remove('active'));img.classList.add('active')});const colorOptions=$('color-options');colorOptions.innerHTML=(p.colors||[]).map(c=>`<button class="color-btn${c.name===S.color?' selected':''}" data-color="${c.name}"><span class="swatch" style="background:${c.value}"></span>${c.name}</button>`).join('');colorOptions.querySelectorAll('.color-btn').forEach(b=>b.onclick=()=>{S.color=b.dataset.color;colorOptions.querySelectorAll('.color-btn').forEach(x=>x.classList.remove('selected'));b.classList.add('selected')});const sizeOptions=$('size-options');sizeOptions.innerHTML=p.sizes.map(s=>`<button class="size-btn" data-size="${s}">${s}</button>`).join('');sizeOptions.querySelectorAll('.size-btn').forEach(b=>b.onclick=()=>{S.size=b.dataset.size;sizeOptions.querySelectorAll('.size-btn').forEach(x=>x.classList.remove('selected'));b.classList.add('selected')})}
function updateBadge(){const n=S.cart.reduce((a,b)=>a+b.qty,0),badge=$('cart-badge');badge.textContent=n;badge.classList.toggle('hidden',!n)}
function addCart(){if(!S.size)return;const hit=S.cart.find(i=>i.id===S.product.id&&i.size===S.size&&i.color===S.color);if(hit)hit.qty++;else S.cart.push({id:S.product.id,name:S.product.name,price:S.product.price,image:S.product.image,size:S.size,color:S.color,qty:1});updateBadge()}
function renderCart(){const cartList=$('cart-list');if(!S.cart.length){cartList.innerHTML='<div class="panel"><h3>Carrito vacio</h3><p>No has agregado productos aun.</p></div>'}else{cartList.innerHTML=S.cart.map((i,idx)=>`<div class="cart-item"><img src="${i.image}" alt="${i.name}"><div class="cart-info"><h3>${i.name}</h3><p>Talla: ${i.size}${i.color?` / Color: ${i.color}`:''}</p><p>Cantidad: ${i.qty}</p><div class="price">${money(i.qty*i.price)}</div><button class="see-link" data-remove="${idx}">Eliminar</button></div></div>`).join('');cartList.querySelectorAll('[data-remove]').forEach(b=>b.onclick=()=>{S.cart.splice(Number(b.dataset.remove),1);renderCart();updateBadge()})}const count=S.cart.reduce((a,b)=>a+b.qty,0),total=S.cart.reduce((a,b)=>a+b.qty*b.price,0);$('sum-count').textContent=count;$('sum-sub').textContent=money(total);$('sum-total').textContent=money(total)}
function renderCheckout(){if(!S.user){navigate('login');return}if(!S.cart.length){navigate('cart');return}$('co-name').value=S.user.name||'';const total=S.cart.reduce((a,b)=>a+b.qty*b.price,0);$('checkout-items').innerHTML=S.cart.map(i=>`<div class="sum-row"><span>${i.name} x${i.qty}</span><span>${money(i.qty*i.price)}</span></div>`).join('');$('checkout-total').textContent=money(total)}
function placeOrder(){const name=$('co-name').value.trim(),address=$('co-address').value.trim(),city=$('co-city').value.trim();if(!name||!address||!city)return;const orders=JSON.parse(localStorage.getItem('tempest_orders')||'[]');orders.push({id:'ORD-'+Date.now().toString(36).toUpperCase(),clientEmail:S.user.email,clientName:name,total:S.cart.reduce((a,b)=>a+b.qty*b.price,0),status:'pendiente',items:[...S.cart],createdAt:new Date().toISOString()});localStorage.setItem('tempest_orders',JSON.stringify(orders));S.cart=[];updateBadge();navigate('orders')}
function renderOrders(){if(!S.user){navigate('login');return}const orders=JSON.parse(localStorage.getItem('tempest_orders')||'[]').filter(o=>o.clientEmail===S.user.email).reverse();$('orders-list').innerHTML=orders.length?orders.map(o=>`<div class="panel" style="margin-bottom:1rem"><h3>${o.id}</h3><div class="row"><span>${new Date(o.createdAt).toLocaleDateString('es-CO')}</span><span class="status ${o.status}">${o.status}</span></div><div class="price" style="margin-top:1rem">${money(o.total)}</div></div>`).join(''):'<div class="panel"><h3>Sin pedidos</h3><p>Tu historial aparecera aqui despues de tu primera compra.</p></div>'}
function renderAdmin(){if(!S.user||S.user.role!=='admin'){navigate('login');return}const orders=JSON.parse(localStorage.getItem('tempest_orders')||'[]'),users=JSON.parse(localStorage.getItem('tempest_users')||'[]');$('stats-grid').innerHTML=`<div class="stat"><strong>${PRODUCTS.length}</strong><span>Productos</span></div><div class="stat"><strong>${orders.length}</strong><span>Pedidos</span></div><div class="stat"><strong>${users.length}</strong><span>Usuarios</span></div><div class="stat"><strong>${money(orders.reduce((a,b)=>a+b.total,0))}</strong><span>Ingresos</span></div>`;$('admin-orders').innerHTML=orders.map(o=>`<tr><td>${o.id}</td><td>${o.clientName}</td><td>${money(o.total)}</td><td><span class="status ${o.status}">${o.status}</span></td></tr>`).join('');$('admin-users').innerHTML=users.map(u=>`<tr><td>${u.name}</td><td>${u.email}</td><td>${u.role}</td></tr>`).join('')}
function renderAuth(){const authArea=$('auth-area');if(S.user){authArea.innerHTML=`<button class="nav-btn" id="logout-btn">${S.user.name.split(' ')[0]} / Salir</button>`;$('logout-btn').onclick=()=>{S.user=null;localStorage.removeItem('tempest_user');renderAuth();navigate('home')}}else authArea.innerHTML='<a href="#" class="nav-btn" data-page="login">Ingresar</a>';$('hero-register').classList.toggle('hidden',!!S.user)}
function navigate(page,data=null){document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));$(page+'-page').classList.add('active');document.querySelectorAll('.nav-link').forEach(a=>a.classList.toggle('active',a.dataset.page===page));S.page=page;scrollTo({top:0,behavior:'smooth'});if(page==='home')renderFeatured();if(page==='catalog')renderCatalog();if(page==='product-detail'&&data)renderDetail(data);if(page==='cart')renderCart();if(page==='checkout')renderCheckout();if(page==='orders')renderOrders();if(page==='admin')renderAdmin()}
document.addEventListener('DOMContentLoaded',()=>{initLightning();loadData();renderAuth();renderFeatured();updateBadge();document.body.addEventListener('click',e=>{const el=e.target.closest('[data-page]');if(!el)return;e.preventDefault();navigate(el.dataset.page)});$('cart-nav').onclick=()=>navigate('cart');$('back-catalog').onclick=e=>{e.preventDefault();navigate('catalog')};$('add-cart').onclick=addCart;$('go-checkout').onclick=()=>navigate('checkout');$('place-order').onclick=placeOrder;$('search-input').oninput=e=>{S.search=e.target.value;renderCatalog()};$('gender-filters').onclick=e=>{const b=e.target.closest('[data-gender]');if(!b)return;S.gender=b.dataset.gender;renderCatalog()};$('login-form').onsubmit=e=>{e.preventDefault();const email=$('login-email').value,pass=$('login-password').value,users=JSON.parse(localStorage.getItem('tempest_users')||'[]'),pw=JSON.parse(localStorage.getItem('tempest_passwords')||'{}'),u=users.find(x=>x.email===email);if(u&&pw[email]===pass){S.user=u;saveUser();renderAuth();navigate(u.role==='admin'?'admin':'home')}};$('register-form').onsubmit=e=>{e.preventDefault();const users=JSON.parse(localStorage.getItem('tempest_users')||'[]'),pw=JSON.parse(localStorage.getItem('tempest_passwords')||'{}');const user={id:Date.now().toString(),name:$('reg-name').value,email:$('reg-email').value,role:'cliente',createdAt:new Date().toISOString()};users.push(user);pw[user.email]=$('reg-password').value;localStorage.setItem('tempest_users',JSON.stringify(users));localStorage.setItem('tempest_passwords',JSON.stringify(pw));S.user=user;saveUser();renderAuth();navigate('home')};document.querySelectorAll('.admin-tab').forEach(btn=>btn.onclick=()=>{document.querySelectorAll('.admin-tab').forEach(x=>x.classList.remove('active'));btn.classList.add('active');$('admin-stats-panel').classList.toggle('hidden',btn.dataset.admin!=='stats');$('admin-orders-panel').classList.toggle('hidden',btn.dataset.admin!=='orders');$('admin-users-panel').classList.toggle('hidden',btn.dataset.admin!=='users')})});
</script>
{% endblock scripts %}
